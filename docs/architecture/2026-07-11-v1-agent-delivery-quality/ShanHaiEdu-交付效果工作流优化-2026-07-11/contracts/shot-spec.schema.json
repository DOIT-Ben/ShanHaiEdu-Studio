{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/schemas/shot-spec.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["shot_id", "beat_id", "start_seconds", "duration_seconds", "viewer_experience", "subject", "action", "context", "framing", "camera_motion", "start_state", "end_state", "narration", "caption", "asset_refs", "continuity_keys", "negative_constraints", "course_anchor_relation", "acceptance_checks"],
  "properties": {
    "shot_id": { "type": "string", "pattern": "^shot_[0-9]{2,3}$" },
    "beat_id": { "type": "string", "pattern": "^beat_[0-9]{2,3}$" },
    "start_seconds": { "type": "number", "minimum": 0 },
    "duration_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 30 },
    "viewer_experience": { "type": "string", "minLength": 5 },
    "subject": { "type": "string", "minLength": 3 },
    "action": { "type": "string", "minLength": 5 },
    "context": { "type": "string", "minLength": 5 },
    "framing": { "type": "string", "minLength": 3 },
    "camera_motion": { "type": "string", "minLength": 3 },
    "start_state": { "type": "string", "minLength": 5 },
    "end_state": { "type": "string", "minLength": 5 },
    "narration": { "type": ["string", "null"] },
    "caption": { "type": ["string", "null"] },
    "asset_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "continuity_keys": { "type": "object", "minProperties": 1 },
    "negative_constraints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "course_anchor_relation": { "type": "string", "minLength": 5 },
    "acceptance_checks": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
