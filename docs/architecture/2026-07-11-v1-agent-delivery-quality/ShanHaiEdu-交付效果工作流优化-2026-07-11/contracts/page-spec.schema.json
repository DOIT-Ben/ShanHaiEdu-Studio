{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/schemas/page-spec.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["page_id", "page_number", "narrative_job", "teaching_action", "student_action", "takeaway_title", "primary_visual_type", "primary_visual_brief", "visible_text_budget", "local_math_layers", "generated_asset_refs", "layout_constraints", "alt_text", "reading_order", "non_color_coding", "media_accessibility", "transition_from_previous", "presenter_note", "acceptance_checks", "objective_ids"],
  "properties": {
    "page_id": { "type": "string", "pattern": "^page_[0-9]{2,3}$" },
    "page_number": { "type": "integer", "minimum": 1, "maximum": 60 },
    "objective_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "narrative_job": { "type": "string", "minLength": 5 },
    "teaching_action": { "type": "string", "minLength": 5 },
    "student_action": { "type": "string", "minLength": 5 },
    "takeaway_title": { "type": "string", "minLength": 2, "maxLength": 40 },
    "primary_visual_type": { "enum": ["immersive_scene", "focused_observation", "process", "comparison", "operation", "relationship", "student_work", "summary"] },
    "primary_visual_brief": { "type": "string", "minLength": 20 },
    "visible_text_budget": { "type": "object", "additionalProperties": false, "required": ["max_lines", "max_characters", "min_font_pt"], "properties": { "max_lines": { "type": "integer", "minimum": 1, "maximum": 8 }, "max_characters": { "type": "integer", "minimum": 1, "maximum": 180 }, "min_font_pt": { "type": "number", "minimum": 18 } } },
    "local_math_layers": { "type": "array", "items": { "type": "object", "required": ["layer_id", "role", "exact_content"], "properties": { "layer_id": { "type": "string" }, "role": { "type": "string" }, "exact_content": {} } } },
    "generated_asset_refs": { "type": "array", "items": { "type": "string" } },
    "layout_constraints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "alt_text": { "type": "string", "minLength": 5 },
    "reading_order": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "non_color_coding": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
    "media_accessibility": { "type": "object", "additionalProperties": false, "required": ["captions_required", "transcript_required"], "properties": { "captions_required": { "type": "boolean" }, "transcript_required": { "type": "boolean" } } },
    "transition_from_previous": { "type": ["string", "null"] },
    "presenter_note": { "type": "string", "minLength": 5 },
    "acceptance_checks": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
