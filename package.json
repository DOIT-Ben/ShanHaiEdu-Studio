{
  "name": "shanhai-edu-studio",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/electron-main.mjs",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/verify-next-build-output.mjs --sanitize",
    "preflight:production": "node scripts/production-preflight.mjs",
    "preflight:container-runtime": "node scripts/container-runtime-preflight.mjs",
    "release:data:backup": "node scripts/release-data-recovery.mjs backup",
    "release:data:verify": "node scripts/release-data-recovery.mjs verify",
    "release:data:restore": "node scripts/release-data-recovery.mjs restore",
    "preflight:deploy-demo": "node scripts/deploy-demo-preflight.mjs",
    "preflight:client-exe": "node scripts/client-exe-readiness.mjs",
    "desktop:smoke": "node scripts/desktop-smoke.mjs",
    "desktop:prepare": "node scripts/prepare-desktop-bundle.mjs",
    "desktop:pack": "npm run build && npm run desktop:prepare && electron-builder --win --config electron-builder.config.cjs",
    "desktop:installer-smoke": "node scripts/desktop-installer-smoke.mjs",
    "test": "node scripts/run-tests.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit",
    "gate:development": "node scripts/development-gates/run-development-gates.mjs",
    "gate:manifest:verify": "node scripts/development-gates/verification-manifest.mjs verify",
    "gate:provider:impact": "node scripts/development-gates/provider-continuity.mjs impact",
    "gate:provider:verify": "node scripts/development-gates/provider-continuity.mjs verify",
    "gate:provider:live": "node scripts/development-gates/provider-continuity/live-runner.mjs",
    "gate:provider:seal": "node scripts/development-gates/provider-continuity/receipt-writer.mjs",
    "verify:local": "node scripts/development-gates/run-verification.mjs",
    "verify:ci": "node scripts/development-gates/run-verification.mjs --require-clean",
    "gate:release": "node scripts/development-gates/release-gate.mjs",
    "test:e2e": "playwright test",
    "test:e2e:m67": "node scripts/run-m67-e2e.mjs",
    "test:e2e:stage1": "playwright test tests/e2e/stage1-foundation.spec.ts --project=chromium-desktop",
    "test:e2e:stage2:preflight": "node scripts/e2e-stage2-preflight.mjs",
    "test:e2e:stage2": "node scripts/run-stage2-e2e.mjs",
    "test:e2e:stage7": "node scripts/run-stage7-e2e.mjs",
    "test:e2e:stage8": "node scripts/run-stage8-e2e.mjs",
    "test:e2e:stage33": "node scripts/run-stage33-e2e.mjs",
    "test:e2e:stage40c": "node scripts/run-stage40c-e2e.mjs",
    "test:e2e:stage3:preflight": "node scripts/e2e-stage3-preflight.mjs",
    "test:e2e:report": "playwright show-report playwright-report",
    "playwright:install": "playwright install chromium firefox",
    "db:generate": "prisma generate",
    "db:init": "node scripts/init-sqlite-schema.mjs",
    "feedback:reconcile": "tsx scripts/reconcile-feedback-storage.mjs",
    "db:push": "prisma db push",
    "test:stage1": "prisma generate && prisma db push && vitest run src/server/workbench/__tests__/stage1-contract.test.ts",
    "test:stage2": "prisma generate && prisma db push && vitest run src/server/workbench/__tests__/stage2-workflow-lite.test.ts",
    "test:stage7": "prisma generate && prisma db push && vitest run src/server/workbench/__tests__/stage7-mainline-contract.test.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.26",
    "@assistant-ui/react-markdown": "0.14.5",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.11",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.11.1",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-stringify": "^6.8.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "openai": "^6.45.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.11",
    "tsx": "4.20.6",
    "yaml": "2.8.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "dotenv": "^17.4.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prisma": "^7.8.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
