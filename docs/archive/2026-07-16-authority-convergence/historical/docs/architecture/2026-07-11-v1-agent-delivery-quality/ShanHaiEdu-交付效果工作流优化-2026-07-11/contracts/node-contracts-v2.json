    {
      "id": "cross_delivery_review",
      "version": "v2",
      "purpose": "Ensure PPT and video form one classroom experience without collapsing into the same artifact.",
      "requiredInputs": [
        "approved_ppt",
        "approved_video",
        "delivery_strategy",
        "course_anchor",
        "lesson_plan"
