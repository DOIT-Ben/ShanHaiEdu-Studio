// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id              String                @id @default(cuid())
  title           String
  status          String                @default("active")
  currentNodeKey  String
  ownerUserId     String?
  grade           String?
  subject         String?
  textbookVersion String?
  lessonTopic     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           LocalUser?            @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  messages        ConversationMessage[]
  nodes           WorkflowNode[]
  artifacts       Artifact[]
  agentRuns       AgentRun[]
  generationJobs  GenerationJob[]
  turnJobs        ConversationTurnJob[]
  memberships     ProjectMembership[]
  auditLogs       AuditLog[]
  feedbackRecords FeedbackRecord[]

  @@index([ownerUserId, updatedAt])
}

model LocalUser {
  id             String              @id
  displayName    String
  role           String              @default("teacher")
  authMode       String              @default("local")
  email          String?             @unique
  passwordHash   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  projects       Project[]
  sessions       AuthSession[]
  memberships    ProjectMembership[]
  auditLogs      AuditLog[]
  csrfTokens     CsrfToken[]
  feedbackRecords FeedbackRecord[]
}

model AuthSession {
  id               String      @id @default(cuid())
  userId           String
  sessionTokenHash String      @unique
  authMode         String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             LocalUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  csrfTokens       CsrfToken[]

  @@index([userId, expiresAt])
}

model ProjectMembership {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  role      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      LocalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, role])
}

model AuditLog {
  id          String     @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  projectId   String?
  metadataJson String    @default("{}")
  createdAt   DateTime   @default(now())
  actor       LocalUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([projectId, createdAt])
  @@index([action, createdAt])
}

model CsrfToken {
  id        String      @id @default(cuid())
  sessionId String
  userId    String
  tokenHash String      @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime    @default(now())
  session   AuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      LocalUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, expiresAt])
  @@index([userId, expiresAt])
}

model ConversationMessage {
  id               String   @id @default(cuid())
  projectId        String
  role             String
  content          String
  artifactRefsJson String   @default("[]")
  metadataJson     String   @default("{}")
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbackRecords  FeedbackRecord[]

  @@index([projectId, createdAt])
}

model WorkflowNode {
  id                 String    @id @default(cuid())
  projectId          String
  key                String
  title              String
  status             String    @default("not_started")
  order              Int
  upstreamNodeKeysJson String  @default("[]")
  approvedArtifactId String?
  staleReason        String?
  updatedAt          DateTime  @updatedAt
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedArtifact   Artifact? @relation("ApprovedArtifact", fields: [approvedArtifactId], references: [id])

  @@unique([projectId, key])
  @@index([projectId, order])
}

model Artifact {
  id                    String         @id @default(cuid())
  projectId             String
  nodeKey               String
  title                 String
  kind                  String
  status                String
  summary               String
  markdownContent       String
  structuredContentJson String         @default("{}")
  version               Int
  isApproved            Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  project               Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedByNodes       WorkflowNode[] @relation("ApprovedArtifact")

  @@index([projectId, nodeKey, version])
}

model AgentRun {
  id           String    @id @default(cuid())
  projectId    String
  nodeKey      String
  status       String
  runtime      String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  errorMessage String?
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, nodeKey, startedAt])
}

model GenerationJob {
  id               String    @id @default(cuid())
  projectId        String
  kind             String
  sourceArtifactId String
  status           String    @default("queued")
  attempts         Int       @default(0)
  maxAttempts      Int       @default(2)
  resultArtifactId String?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  startedAt        DateTime?
  finishedAt       DateTime?
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, createdAt])
  @@index([sourceArtifactId])
}

model FeedbackRecord {
  id                       String               @id
  receipt                  String               @unique
  category                 String
  description              String
  severity                 String?
  status                   String               @default("processing")
  idempotencyKey           String
  requestFingerprint       String
  origin                   String               @default("global")
  projectId                String?
  messageId                String?
  pageRoute                String
  appVersion               String
  clientContextJson        String               @default("{}")
  stagingKey               String               @unique
  failureCode              String?
  reconciliationOwner      String?
  reconciliationLeaseUntil DateTime?
  createdByUserId          String
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  submittedAt              DateTime?
  createdBy                LocalUser            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  project                  Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  message                  ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  attachments              FeedbackAttachment[]

  @@unique([createdByUserId, idempotencyKey])
  @@index([status, createdAt])
  @@index([category, createdAt])
  @@index([severity, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([projectId, createdAt])
}

model FeedbackAttachment {
  id           String         @id
  feedbackId   String
  originalName String
  mimeType     String
  extension    String
  byteSize     Int
  width        Int
  height       Int
  sha256       String
  storageKey   String         @unique
  createdAt    DateTime       @default(now())
  feedback     FeedbackRecord @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId, createdAt])
}

model ConversationTurnJob {
  id                 String    @id @default(cuid())
  projectId          String
  teacherMessageId   String
  assistantMessageId String?
  status             String    @default("queued")
  attempts           Int       @default(0)
  maxAttempts        Int       @default(2)
  idempotencyKey     String?
  lockedBy           String?
  lockedUntil        DateTime?
  errorCode          String?
  errorMessage       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  startedAt          DateTime?
  finishedAt         DateTime?
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, idempotencyKey])
  @@index([projectId, status, createdAt])
  @@index([teacherMessageId])
}
