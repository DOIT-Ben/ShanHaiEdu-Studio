{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/schemas/ppt-director-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "summary", "targetLocators", "nextToolIntents", "assumptions", "stopConditions", "communication_job", "presentation_brief", "evidence_bindings", "learning_objectives", "deck_narrative", "learning_objective_coverage", "visual_system", "page_specs", "asset_requests", "sample_plan", "self_check"],
  "properties": {
    "decision": { "enum": ["plan", "repair", "needs_input", "blocked"] },
    "summary": { "type": "string", "minLength": 1 },
    "targetLocators": { "type": "array", "items": { "type": "string" } },
    "nextToolIntents": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "stopConditions": { "type": "array", "items": { "type": "string" } },
    "communication_job": { "type": "string", "minLength": 20 },
    "presentation_brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grade", "subject", "topic", "audience", "use_case", "target_slide_count", "objective_ids", "evidence_refs"],
      "properties": {
        "grade": { "type": "string", "minLength": 1 },
        "subject": { "type": "string", "minLength": 1 },
        "topic": { "type": "string", "minLength": 1 },
        "audience": { "type": "string", "minLength": 1 },
        "use_case": { "enum": ["public_lesson", "competition_lesson", "ordinary_lesson"] },
        "target_slide_count": { "type": "integer", "minimum": 1, "maximum": 60 },
        "objective_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "evidence_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "source_artifact_id", "source_type", "page_refs", "claims", "digest"],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "source_artifact_id": { "type": "string", "minLength": 1 },
          "source_type": { "enum": ["textbook", "curriculum_standard", "teacher_material"] },
          "page_refs": { "type": "array", "items": { "type": "string" } },
          "claims": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "digest": { "type": "string", "minLength": 1 }
        }
      }
    },
    "learning_objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objective_id", "statement", "evidence_refs"],
        "properties": {
          "objective_id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "deck_narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opening_tension", "learning_progression", "closing_resolution", "page_count", "page_count_rationale"],
      "properties": {
        "opening_tension": { "type": "string", "minLength": 5 },
        "learning_progression": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 2 } },
        "closing_resolution": { "type": "string", "minLength": 5 },
        "page_count": { "type": "integer", "minimum": 1, "maximum": 60 },
        "page_count_rationale": { "type": "string", "minLength": 5 }
      }
    },
    "learning_objective_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objective_id", "concepts", "page_ids"],
        "properties": {
          "objective_id": { "type": "string", "minLength": 1 },
          "concepts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "page_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^page_[0-9]{2,3}$" } }
        }
      }
    },
    "visual_system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "palette", "material_language", "lighting", "camera", "typography", "layout_families"],
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "palette": { "type": "array", "minItems": 2, "items": { "type": "string" } },
        "material_language": { "type": "string", "minLength": 1 },
        "lighting": { "type": "string", "minLength": 1 },
        "camera": { "type": "string", "minLength": 1 },
        "typography": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title_min_pt", "body_min_pt", "font_family"],
          "properties": {
            "title_min_pt": { "type": "number", "minimum": 18 },
            "body_min_pt": { "type": "number", "minimum": 18 },
            "font_family": { "type": "string", "minLength": 1 }
          }
        },
        "layout_families": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "enum": ["immersive_scene", "focused_observation", "operation", "comparison", "summary"] } }
      }
    },
    "page_specs": { "type": "array", "minItems": 1, "items": { "$ref": "page-spec.schema.json" } },
    "asset_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset_id", "page_ids", "asset_role", "generation_mode", "aspect_ratio", "composition_safe_zone", "prompt", "negative_prompt", "local_overlay_requirements", "reuse_policy"],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "page_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^page_[0-9]{2,3}$" } },
          "asset_role": { "type": "string", "minLength": 3 },
          "generation_mode": { "enum": ["generate", "reconstruct", "local_deterministic", "reuse_approved"] },
          "aspect_ratio": { "type": "string", "minLength": 3 },
          "composition_safe_zone": { "type": "string", "minLength": 3 },
          "prompt": { "type": "string" },
          "negative_prompt": { "type": "string" },
          "local_overlay_requirements": { "type": "array", "items": { "type": "string" } },
          "reuse_policy": { "type": "string", "minLength": 3 }
        }
      }
    },
    "sample_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_page_ids", "rationales", "required_risk_coverage"],
      "properties": {
        "sample_page_ids": { "type": "array", "minItems": 3, "maxItems": 4, "uniqueItems": true, "items": { "type": "string", "pattern": "^page_[0-9]{2,3}$" } },
        "rationales": {
          "type": "array",
          "minItems": 3,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page_id", "rationale"],
            "properties": {
              "page_id": { "type": "string", "pattern": "^page_[0-9]{2,3}$" },
              "rationale": { "type": "string", "minLength": 5 }
            }
          }
        },
        "required_risk_coverage": { "type": "array", "minItems": 4, "uniqueItems": true, "items": { "enum": ["narrative", "layout", "math", "visual"] } }
      }
    },
    "self_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_objectives_covered", "page_numbers_continuous", "all_assets_bound", "violations"],
      "properties": {
        "all_objectives_covered": { "type": "boolean" },
        "page_numbers_continuous": { "type": "boolean" },
        "all_assets_bound": { "type": "boolean" },
        "violations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
