{
  "name": "shanhai-edu-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "test": "node --test tests/*.test.mjs && vitest run tests/agent-runtime",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:stage1": "playwright test tests/e2e/stage1-foundation.spec.ts --project=chromium-desktop",
    "test:e2e:stage2:preflight": "node scripts/e2e-stage2-preflight.mjs",
    "test:e2e:stage2": "node scripts/run-stage2-e2e.mjs",
    "test:e2e:report": "playwright show-report playwright-report",
    "playwright:install": "playwright install chromium",
    "db:generate": "prisma generate",
    "db:init": "node scripts/init-sqlite-schema.mjs",
    "db:push": "prisma db push",
    "test:stage1": "prisma generate && node scripts/init-sqlite-schema.mjs && vitest run src/server/workbench/__tests__/stage1-contract.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.11",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.0.0",
    "openai": "^6.45.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
