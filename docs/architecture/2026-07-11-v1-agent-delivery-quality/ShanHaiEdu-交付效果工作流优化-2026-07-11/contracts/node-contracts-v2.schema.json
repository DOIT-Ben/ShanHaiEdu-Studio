{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanhaiedu.local/schemas/node-contracts-v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "principles", "contracts"],
  "properties": {
    "schemaVersion": { "const": "2.1" },
    "principles": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contract" }
    }
  },
  "$defs": {
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule", "enforcement"],
        "properties": {
          "rule": { "type": "string", "minLength": 1 },
          "enforcement": { "const": "must" }
        }
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "enforcement"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "enforcement": { "type": "string", "enum": ["must", "should", "may"] }
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "purpose", "requiredInputs", "requiredOutputs", "forbidden", "qualityGates", "recommendedNext", "repairTarget"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "version": { "type": "string", "pattern": "^v[0-9]+$" },
        "purpose": { "type": "string", "minLength": 10 },
        "requiredInputs": { "$ref": "#/$defs/nonEmptyStrings" },
        "requiredOutputs": { "$ref": "#/$defs/nonEmptyStrings" },
        "forbidden": { "$ref": "#/$defs/rules" },
        "qualityGates": { "$ref": "#/$defs/criteria" },
        "recommendedNext": { "$ref": "#/$defs/nonEmptyStrings" },
        "capsuleTransitions": { "$ref": "#/$defs/nonEmptyStrings" },
        "transitionRules": { "$ref": "#/$defs/nonEmptyStrings" },
        "repairTarget": { "type": "string", "minLength": 1 }
      }
    }
  }
}
