// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                    String                          @id @default(cuid())
  title                 String
  status                String                          @default("active")
  currentNodeKey        String
  ownerUserId           String?
  grade                 String?
  subject               String?
  textbookVersion       String?
  lessonTopic           String?
  archivedAt            DateTime?
  deletedAt             DateTime?
  lifecycleVersion      Int                             @default(0)
  intentEpoch           Int                             @default(0)
  generationIntensity   String                          @default("standard")
  intensityVersion      Int                             @default(0)
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  owner                 LocalUser?                      @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  messages              ConversationMessage[]
  artifacts             Artifact[]
  generationJobs        GenerationJob[]
  videoShots            VideoShot[]
  turnJobs              ConversationTurnJob[]
  executionLease        ProjectExecutionLease?
  runInputSnapshots     RunInputSnapshot[]
  stagedArtifactCommits StagedArtifactCommit[]
  validationReports     ValidationReportRecord[]
  criticReports         CriticReportRecord[]
  qualityDecisions      QualityDecisionRecord[]
  memberships           ProjectMembership[]
  auditLogs             AuditLog[]
  feedbackRecords       FeedbackRecord[]
  messageReactions      MessageReaction[]
  taskAggregates        TaskAggregate[]
  agentEvents           AgentEventRecord[]
  toolInvocations       ToolInvocationRecord[]
  observations          ObservationRecord[]
  semanticSnapshots     SemanticContextSnapshotRecord[]

  @@index([ownerUserId, updatedAt])
  @@index([archivedAt, deletedAt, updatedAt])
}

model TaskAggregate {
  taskId          String   @id
  projectId       String
  intentEpoch     Int
  taskBriefJson   String
  intentGrantJson String
  planId          String
  planRevision    Int      @default(0)
  status          String   @default("active")
  checkpointJson  String   @default("null")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, intentEpoch])
  @@index([projectId, status, updatedAt])
}

model AgentEventRecord {
  eventId      String   @id
  projectId    String
  taskId       String
  runId        String
  intentEpoch  Int
  sequence     Int
  kind         String
  visibility   String
  envelopeJson String
  payloadJson  String
  occurredAt   DateTime
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sequence])
  @@index([projectId, taskId, sequence])
}

model ToolInvocationRecord {
  invocationId          String              @id
  projectId             String
  taskId                String
  intentEpoch           Int
  planRevision          Int
  toolName              String
  executionEnvelopeJson String
  requestJson           String
  idempotencyKey        String
  status                String              @default("running")
  artifactId            String?
  observationId         String?
  startedAt             DateTime            @default(now())
  finishedAt            DateTime?
  project               Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  observations          ObservationRecord[]

  @@unique([projectId, idempotencyKey])
  @@index([projectId, taskId, startedAt])
}

model ObservationRecord {
  observationId   String                @id
  projectId       String
  taskId          String
  invocationId    String?
  intentEpoch     Int
  status          String
  reasonCodesJson String                @default("[]")
  payloadJson     String
  artifactId      String?
  createdAt       DateTime              @default(now())
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invocation      ToolInvocationRecord? @relation(fields: [invocationId], references: [invocationId], onDelete: SetNull)

  @@index([projectId, taskId, createdAt])
  @@index([invocationId])
}

model SemanticContextSnapshotRecord {
  snapshotId        String   @id
  projectId         String
  taskId            String
  intentEpoch       Int
  planRevision      Int
  snapshotDigest    String
  payloadJson       String
  lastEventSequence Int      @default(0)
  createdAt         DateTime @default(now())
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, taskId, intentEpoch, planRevision])
  @@index([projectId, createdAt])
}

model LocalUser {
  id               String              @id
  displayName      String
  role             String              @default("teacher")
  authMode         String              @default("local")
  email            String?             @unique
  passwordHash     String?
  disabledAt       DateTime?
  disabledReason   String?
  lastLoginAt      DateTime?
  passwordResetAt  DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  projects         Project[]
  sessions         AuthSession[]
  memberships      ProjectMembership[]
  auditLogs        AuditLog[]
  csrfTokens       CsrfToken[]
  feedbackRecords  FeedbackRecord[]
  messageReactions MessageReaction[]
}

model AuthSession {
  id               String      @id @default(cuid())
  userId           String
  sessionTokenHash String      @unique
  authMode         String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             LocalUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  csrfTokens       CsrfToken[]

  @@index([userId, expiresAt])
}

model ProjectMembership {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  role      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      LocalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, role])
}

model AuditLog {
  id           String     @id @default(cuid())
  actorUserId  String?
  action       String
  targetType   String
  targetId     String?
  projectId    String?
  metadataJson String     @default("{}")
  createdAt    DateTime   @default(now())
  actor        LocalUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([projectId, createdAt])
  @@index([action, createdAt])
}

model OrchestrationAuditEvent {
  sequence                Int      @id @default(autoincrement())
  eventId                 String   @unique
  attemptId               String?
  recordType              String
  outcome                 String?
  operationKind           String
  authority               String
  claimedProjectId        String?
  resolvedProjectId       String?
  actorUserId             String
  actorAuthMode           String
  authSessionDigest       String?
  taskId                   String?
  turnJobId                String?
  teacherMessageId         String?
  toolInvocationId         String?
  intentEpoch             Int?
  planRevision            Int?
  planId                  String?
  toolOrdinal             Int?
  toolName                String?
  actionDigest            String?
  idempotencyKey          String?
  observationId           String?
  invocationStatus        String?
  executionEnvelopeDigest String?
  requestDigest           String?
  reasonCode              String?
  payloadJson             String   @default("{}")
  eventDigest             String   @unique
  occurredAt              DateTime
  createdAt               DateTime @default(now())

  @@unique([attemptId, recordType])
  @@unique([resolvedProjectId, taskId, intentEpoch, toolOrdinal, recordType])
  @@unique([toolInvocationId, recordType])
  @@index([claimedProjectId, sequence])
  @@index([resolvedProjectId, sequence])
  @@index([taskId, intentEpoch, sequence])
  @@index([turnJobId, sequence])
  @@index([toolInvocationId, sequence])
  @@index([observationId, sequence])
  @@index([idempotencyKey, sequence])
  @@index([authority, operationKind, sequence])
}

model CsrfToken {
  id         String      @id @default(cuid())
  sessionId  String
  userId     String
  tokenHash  String      @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime    @default(now())
  session    AuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       LocalUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, expiresAt])
  @@index([userId, expiresAt])
}

model ConversationMessage {
  id               String            @id @default(cuid())
  projectId        String
  role             String
  content          String
  partsJson        String            @default("[]")
  artifactRefsJson String            @default("[]")
  metadataJson     String            @default("{}")
  createdAt        DateTime          @default(now())
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbackRecords  FeedbackRecord[]
  reactions        MessageReaction[]

  @@index([projectId, createdAt])
}

model Artifact {
  id                    String                  @id @default(cuid())
  projectId             String
  taskId                String?
  taskBriefDigest       String?
  intentEpoch           Int?
  planRevision          Int?
  origin                String                  @default("legacy")
  nodeKey               String
  title                 String
  kind                  String
  status                String
  summary               String
  markdownContent       String
  structuredContentJson String                  @default("{}")
  version               Int
  isApproved            Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  project               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stagedCommit          StagedArtifactCommit?   @relation("StagedArtifactResult")
  validationReport      ValidationReportRecord?
  criticReports         CriticReportRecord[]
  qualityDecisions      QualityDecisionRecord[]

  @@index([projectId, nodeKey, version])
  @@index([projectId, intentEpoch, kind])
  @@index([taskId])
}

model GenerationJob {
  id                   String                  @id @default(cuid())
  projectId            String
  kind                 String
  sourceArtifactId     String
  unitId               String?
  runInputSnapshotId   String?
  intentEpoch          Int                     @default(0)
  idempotencyKey       String?
  inputHash            String?
  providerTaskId       String?
  pollState            String                  @default("not_started")
  providerAcceptedAt   DateTime?
  lastPolledAt         DateTime?
  status               String                  @default("queued")
  attempts             Int                     @default(0)
  maxAttempts          Int                     @default(2)
  resultArtifactId     String?
  providerResultJson   String?
  countsAsProviderSubmission Boolean                 @default(true)
  errorMessage         String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  startedAt            DateTime?
  finishedAt           DateTime?
  project              Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runInputSnapshot     RunInputSnapshot?       @relation(fields: [runInputSnapshotId], references: [id], onDelete: SetNull)
  stagedArtifactCommit StagedArtifactCommit?
  validationReport     ValidationReportRecord?

  @@unique([projectId, idempotencyKey])
  @@index([projectId, status, createdAt])
  @@index([sourceArtifactId])
  @@index([projectId, kind, unitId, createdAt])
  @@index([runInputSnapshotId])
}

model VideoShot {
  id                 String   @id @default(cuid())
  projectId          String
  sourceArtifactId   String
  shotId             String
  ordinal            Int
  inputHash          String
  providerTaskId     String?
  selectedArtifactId String?
  status             String   @default("planned")
  qaJson             String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sourceArtifactId, shotId])
  @@index([projectId, sourceArtifactId, ordinal])
  @@index([projectId, status, updatedAt])
}

model StagedArtifactCommit {
  id                    String                  @id @default(cuid())
  projectId             String
  generationJobId       String                  @unique
  state                 String                  @default("awaiting_result")
  nodeKey               String?
  kind                  String?
  title                 String?
  artifactStatus        String?
  summary               String?
  markdownContent       String?
  structuredContentJson String                  @default("{}")
  storageRefsJson       String                  @default("[]")
  intentEpoch           Int
  inputHash             String
  holderId              String?
  fencingToken          Int?
  actorUserId           String?
  actorAuthMode         String?
  authSessionId         String?
  resultArtifactId      String?                 @unique
  quarantineReason      String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  committedAt           DateTime?
  project               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generationJob         GenerationJob           @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  resultArtifact        Artifact?               @relation("StagedArtifactResult", fields: [resultArtifactId], references: [id], onDelete: SetNull)
  validationReport      ValidationReportRecord?

  @@index([projectId, state, createdAt])
}

model ValidationReportRecord {
  id                     String                @id
  projectId              String
  capabilityId           String
  stage                  String
  authority              String
  domain                 String
  targetKind             String
  targetId               String?
  targetVersion          Int?
  targetDigest           String?
  inputHash              String?
  intentEpoch            Int?
  contractId             String
  contractVersion        String
  overallStatus          String
  reportDigest           String
  payloadJson            String
  artifactId             String?               @unique
  generationJobId        String?               @unique
  stagedArtifactCommitId String?               @unique
  createdAt              DateTime
  project                Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact               Artifact?             @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  generationJob          GenerationJob?        @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  stagedArtifactCommit   StagedArtifactCommit? @relation(fields: [stagedArtifactCommitId], references: [id], onDelete: Cascade)

  @@index([projectId, stage, createdAt])
  @@index([projectId, reportDigest])
  @@index([targetKind, targetId])
}

model CriticReportRecord {
  id                 String                  @id
  projectId          String
  artifactId         String
  reportDigest       String
  authority          String
  status             String
  domain             String
  stage              String
  targetVersion      Int
  targetDigest       String
  productionPath     String
  inputHash          String?
  rubricId           String
  rubricVersion      String
  rubricDigest       String
  validationRefsJson String
  payloadJson        String
  createdAt          DateTime
  project            Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact           Artifact                @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  qualityDecisions   QualityDecisionRecord[]

  @@unique([projectId, reportDigest])
  @@index([projectId, artifactId, createdAt])
}

model QualityDecisionRecord {
  id                    String              @id
  projectId             String
  artifactId            String
  criticReportId        String?
  decisionDigest        String
  authority             String
  domain                String
  stage                 String
  targetVersion         Int
  targetDigest          String
  productionPath        String
  inputHash             String?
  outcome               String
  weightedScore         Float?
  reasonCodesJson       String
  nextAction            String
  repairTargetsJson     String
  deliveryEligibility   String
  validationDigestsJson String
  rubricDigest          String
  payloadJson           String
  createdAt             DateTime
  project               Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact              Artifact            @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  criticReport          CriticReportRecord? @relation(fields: [criticReportId], references: [id], onDelete: SetNull)

  @@unique([projectId, decisionDigest])
  @@index([projectId, artifactId, createdAt])
  @@index([criticReportId])
}

model RunInputSnapshot {
  id                    String          @id @default(cuid())
  projectId             String
  intentEpoch           Int
  capabilityId          String
  sourceArtifactIdsJson String          @default("[]")
  payloadJson           String
  inputHash             String
  createdAt             DateTime        @default(now())
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generationJobs        GenerationJob[]

  @@unique([projectId, inputHash])
  @@index([projectId, intentEpoch, createdAt])
}

model FeedbackRecord {
  id                       String               @id
  receipt                  String               @unique
  category                 String
  description              String
  severity                 String?
  status                   String               @default("processing")
  idempotencyKey           String
  requestFingerprint       String
  origin                   String               @default("global")
  projectId                String?
  messageId                String?
  pageRoute                String
  appVersion               String
  clientContextJson        String               @default("{}")
  stagingKey               String               @unique
  failureCode              String?
  reconciliationOwner      String?
  reconciliationLeaseUntil DateTime?
  createdByUserId          String
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  submittedAt              DateTime?
  createdBy                LocalUser            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  project                  Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  message                  ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  attachments              FeedbackAttachment[]

  @@unique([createdByUserId, idempotencyKey])
  @@index([status, createdAt])
  @@index([category, createdAt])
  @@index([severity, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([projectId, createdAt])
}

model FeedbackAttachment {
  id           String         @id
  feedbackId   String
  kind         String         @default("issue")
  originalName String
  mimeType     String
  extension    String
  byteSize     Int
  width        Int
  height       Int
  sha256       String
  storageKey   String         @unique
  createdAt    DateTime       @default(now())
  feedback     FeedbackRecord @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId, createdAt])
}

model MessageReaction {
  id              String              @id @default(cuid())
  projectId       String
  messageId       String
  createdByUserId String
  value           String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message         ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdBy       LocalUser           @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([messageId, createdByUserId])
  @@index([projectId, createdByUserId, updatedAt])
}

model ConversationTurnJob {
  id                  String    @id @default(cuid())
  projectId           String
  teacherMessageId    String
  assistantMessageId  String?
  status              String    @default("queued")
  attempts            Int       @default(0)
  maxAttempts         Int       @default(2)
  idempotencyKey      String?
  actorUserId         String?
  actorAuthMode       String?
  authSessionId       String?
  fencingToken        Int?
  generationIntensity String    @default("standard")
  intensityVersion    Int       @default(0)
  lockedBy            String?
  lockedUntil         DateTime?
  errorCode           String?
  errorMessage        String?
  failureCategory     String?
  failureRetryability String?
  failureEvidenceDigest String?
  recoveryEvidenceDigest String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  startedAt           DateTime?
  finishedAt          DateTime?
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, idempotencyKey])
  @@index([projectId, status, createdAt])
  @@index([teacherMessageId])
}

model ProjectExecutionLease {
  projectId    String   @id
  holderId     String
  fencingToken Int      @default(1)
  leasedUntil  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([leasedUntil])
}
