        }
      ],
      "repairTarget": "timeline_or_media_layer",
      "recommendedNext": [
        "video_final_review"
      ]
    },
    {
      "id": "video_final_review",
      "version": "v2",
      "purpose": "Review the assembled MP4 for timeline integrity, narrative effect, sound, captions, and classroom landing.",
      "requiredInputs": [
        "assembled_video",
        "video_beat_sheet",
        "video_shot_specs",
        "course_anchor",
        "caption_track",
        "audio_mix"
      ],
      "requiredOutputs": [
        "artifact_truth",
        "final_score",
        "timeline_findings",
        "audio_findings",
        "caption_findings",
        "content_findings",
        "repair_routes"
      ],
      "forbidden": [
        {
          "rule": "Buffer byte concatenation",
          "enforcement": "must"
        },
        {
          "rule": "Container-only approval",
          "enforcement": "must"
        },
        {
          "rule": "Treating long freezes as intentional without beat evidence",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Timeline uses valid timestamps and full decode",
