    {
      "id": "video_segment_review",
      "version": "v2",
      "purpose": "Review each real generated clip against its ShotSpec before assembly.",
      "requiredInputs": [
        "video_segments",
        "video_shot_specs",
        "video_asset_bible"
      ],
      "requiredOutputs": [
        "required_shot_ids",
        "approved_shot_ids",
        "shot_scores",
        "technical_checks",
        "continuity_findings",
        "failed_shot_ids",
        "repair_routes"
      ],
      "forbidden": [
        {
          "rule": "Approving from MP4 headers alone",
          "enforcement": "must"
        },
        {
          "rule": "Assembling failed clips",
          "enforcement": "must"
        },
        {
          "rule": "Whole-video regeneration for a single failed shot",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Every required shot ID has exactly one reviewed segment",
          "enforcement": "must"
        },
        {
          "criterion": "approved_shot_ids equals required_shot_ids before timeline assembly",
          "enforcement": "must"
        },
        {
          "criterion": "Full decode passes",
          "enforcement": "must"
        },
        {
          "criterion": "Duration is within tolerance",
          "enforcement": "must"
        },
        {
          "criterion": "Subject/action/count/continuity pass",
          "enforcement": "must"
        },
        {
          "criterion": "No unintended black or freeze interval",
          "enforcement": "must"
        },
        {
          "criterion": "Weighted shot score at least 80",
          "enforcement": "should"
        }
      ],
      "transitionRules": [
        "Proceed only when set(approved_shot_ids) == set(required_shot_ids); otherwise rerun video_segment_generation for failed_shot_ids only"
      ],
      "repairTarget": "failed_shot_ids",
      "recommendedNext": [
        "video_timeline_assembly"
      ]
    },
    {
      "id": "video_segment_generation",
      "version": "v2",
      "purpose": "Generate one real video clip for exactly one approved ShotSpec using resolved video assets.",
      "requiredInputs": [
        "approved_shot_spec",
        "resolved_video_assets",
        "provider_profile"
      ],
      "requiredOutputs": [
        "shot_id",
        "video_file",
        "actual_duration",
        "actual_stream_profile",
        "provider_metadata",
        "source_asset_ids"
      ],
      "forbidden": [
        {
          "rule": "Batching unrelated shots into one prompt",
          "enforcement": "must"
        },
        {
          "rule": "Using unresolved or PPT assets",
          "enforcement": "must"
        },
        {
          "rule": "Accepting generated text or exact math when deterministic overlays are required",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "File fully decodes",
          "enforcement": "should"
        },
        {
          "criterion": "Actual profile is recorded",
          "enforcement": "must"
        },
        {
          "criterion": "shot_id and source assets are traceable",
          "enforcement": "should"
        },
        {
          "criterion": "No placeholder or smoke file is accepted",
          "enforcement": "must"
        }
      ],
      "repairTarget": "shot_id",
      "recommendedNext": [
        "video_segment_review"
      ]
    },
    {
      "id": "video_timeline_assembly",
      "version": "v2",
      "purpose": "Normalize and assemble approved clips, overlays, captions, narration, and music into a valid media timeline.",
      "requiredInputs": [
        "approved_video_segments",
        "timeline_plan",
        "caption_track",
        "audio_mix_plan",
        "delivery_profile"
      ],
      "requiredOutputs": [
        "assembled_video",
        "normalized_stream_profile",
        "actual_duration",
        "timeline_manifest",
        "caption_manifest",
        "audio_manifest"
      ],
      "forbidden": [
        {
          "rule": "Byte-concatenating MP4 files",
          "enforcement": "must"
        },
        {
          "rule": "Reordering approved shots",
          "enforcement": "must"
        },
        {
          "rule": "Adding undocumented transitions or content",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "FFmpeg concat/filter or equivalent media-aware assembly is used",
