{
  "schemaVersion": "2.1",
  "principles": [
    "Agent proposes; contracts and gates decide; tools execute; artifacts prove.",
    "PPT and video share evidence and the course anchor, not page scripts or creative structure.",
    "A passed technical file gate does not imply a passed delivery-effect gate.",
    "Repair the smallest failed page, shot, asset, caption, audio track, or package claim.",
    "nextOnPass is advisory for Agent planning or internal to a deterministic capsule; it is not a mandatory top-level transition."
  ],
  "contracts": [
    {
      "id": "delivery_strategy",
      "version": "v2",
      "purpose": "Turn approved teaching intent and evidence into separate PPT and video communication jobs.",
      "requiredInputs": [
        "requirement_spec",
        "lesson_plan",
        "evidence_package",
        "course_anchor"
      ],
      "requiredOutputs": [
        "audience",
        "classroom_job",
        "central_learning_change",
        "evidence_scope",
        "ppt_role",
        "video_role",
        "course_anchor_ref",
        "cross_delivery_constraints",
        "non_goals"
      ],
      "forbidden": [
        {
          "rule": "Using PPT page scripts as the video creative brief",
          "enforcement": "must"
        },
        {
          "rule": "Inventing textbook facts",
          "enforcement": "must"
        },
        {
          "rule": "Treating a file list as a delivery strategy",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Every output is evidence-linked",
          "enforcement": "must"
        },
        {
          "criterion": "PPT and video roles are materially different",
          "enforcement": "should"
        },
        {
          "criterion": "Course anchor does not reveal the lesson conclusion",
          "enforcement": "must"
        }
      ],
      "repairTarget": "delivery_strategy",
      "recommendedNext": [
        "visual_system",
        "ppt_narrative",
        "video_concept_set"
      ]
    },
    {
      "id": "course_anchor",
      "version": "v2",
      "purpose": "Define the only required bridge from an independent intro video back to the classroom task.",
      "requiredInputs": [
        "lesson_plan",
        "evidence_package",
        "instruction_intent"
      ],
      "requiredOutputs": [
        "anchor_trigger",
        "classroom_question",
        "do_not_explain",
        "handoff_moment",
        "evidence_refs"
      ],
      "forbidden": [
        {
          "rule": "Explaining the target conclusion",
          "enforcement": "must"
        },
        {
          "rule": "Using the full lesson plan as video content",
          "enforcement": "must"
        },
        {
          "rule": "Inventing evidence",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "All claims link to evidence",
          "enforcement": "must"
        },
        {
          "criterion": "The classroom question is answerable only after classroom activity",
          "enforcement": "should"
        },
        {
          "criterion": "The video can remain independently understandable",
          "enforcement": "should"
        }
      ],
      "repairTarget": "course_anchor",
      "recommendedNext": [
        "delivery_strategy"
      ]
    },
    {
      "id": "visual_system",
      "version": "v2",
      "purpose": "Define reusable visual identity without prescribing repeated card layouts.",
      "requiredInputs": [
        "delivery_strategy",
        "audience_profile"
      ],
      "requiredOutputs": [
        "palette",
        "typography",
        "shape_language",
        "texture",
        "motion_character",
        "accessibility_targets",
        "avoidance_rules"
      ],
      "forbidden": [
        {
          "rule": "UI dashboard defaults",
          "enforcement": "must"
        },
        {
          "rule": "Color-only meaning",
          "enforcement": "must"
        },
        {
          "rule": "Unlicensed fonts or assets",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Contrast targets are measurable",
          "enforcement": "should"
        },
        {
          "criterion": "Rules work for PPT and video without forcing identical layouts",
          "enforcement": "should"
        },
        {
          "criterion": "Avoidance rules are testable",
          "enforcement": "should"
        }
      ],
      "repairTarget": "visual_system",
      "recommendedNext": [
        "ppt_asset_plan",
        "video_asset_bible"
      ]
    },
    {
      "id": "ppt_narrative",
      "version": "v2",
      "purpose": "Define the cumulative learning story before deciding individual slide layouts.",
      "requiredInputs": [
        "delivery_strategy",
        "lesson_plan",
        "evidence_package"
      ],
      "requiredOutputs": [
        "communication_job",
        "opening_tension",
        "learning_progression",
        "section_beats",
        "closing_resolution",
        "page_count_rationale"
      ],
      "forbidden": [
        {
          "rule": "Agenda-only structure",
          "enforcement": "must"
        },
        {
          "rule": "One slide per lesson-plan heading",
          "enforcement": "must"
        },
        {
          "rule": "Fixing page count before the learning progression",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Each beat creates the need for the next",
          "enforcement": "should"
        },
        {
          "criterion": "Opening and closing resolve the same learning question",
          "enforcement": "should"
        },
        {
          "criterion": "Every requested teaching activity has an explicit place",
          "enforcement": "should"
        }
      ],
      "repairTarget": "ppt_narrative",
      "recommendedNext": [
        "ppt_page_specs"
      ]
    },
    {
      "id": "ppt_page_specs",
      "version": "v2",
      "purpose": "Create one executable PageSpec per slide with a single teaching and narrative job.",
      "requiredInputs": [
        "ppt_narrative",
        "lesson_plan",
        "evidence_package"
      ],
      "requiredOutputs": [
        "learning_objective_coverage",
        "page_id",
        "page_number",
        "narrative_job",
        "teaching_action",
        "student_action",
        "takeaway_title",
        "primary_visual_type",
        "primary_visual_brief",
        "visible_text_budget",
        "local_math_layers",
        "layout_constraints",
        "alt_text",
        "reading_order",
        "non_color_coding",
        "media_accessibility",
        "transition_from_previous",
        "presenter_note",
        "acceptance_checks"
      ],
      "forbidden": [
        {
          "rule": "Merged page ranges",
          "enforcement": "must"
        },
        {
          "rule": "Generic topic titles",
          "enforcement": "must"
        },
        {
          "rule": "More than one primary teaching action",
          "enforcement": "must"
        },
        {
          "rule": "Baking exact Chinese text, formulas, or counts into generated images",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "All page numbers are unique and continuous",
          "enforcement": "must"
        },
        {
          "criterion": "Every approved learning objective maps to one or more pages and no required concept is omitted",
          "enforcement": "must"
        },
        {
          "criterion": "Every page has a primary visual that explains the teaching action",
          "enforcement": "should"
        },
        {
          "criterion": "Every meaningful visual has alt text and an explicit reading order",
          "enforcement": "must"
        },
        {
          "criterion": "Meaning is not encoded by color alone and embedded media declares caption/transcript requirements",
          "enforcement": "should"
        },
        {
          "criterion": "No consecutive layout silhouette repeats more than twice",
          "enforcement": "should"
        },
        {
          "criterion": "All mathematical facts have evidence or deterministic layers",
          "enforcement": "must"
        }
      ],
      "repairTarget": "failed_page_ids",
      "recommendedNext": [
        "ppt_asset_plan"
      ]
    },
    {
      "id": "ppt_asset_plan",
      "version": "v2",
      "purpose": "Bind every generated, reconstructed, or local visual asset to PageSpec IDs.",
      "requiredInputs": [
        "ppt_page_specs",
        "visual_system"
      ],
      "requiredOutputs": [
        "asset_id",
        "page_ids",
        "asset_role",
        "generation_mode",
        "aspect_ratio",
        "composition_safe_zone",
        "prompt",
        "negative_prompt",
        "local_overlay_requirements",
        "reuse_policy"
      ],
      "forbidden": [
        {
          "rule": "One generic image for the entire deck unless it is an approved reusable background",
          "enforcement": "must"
        },
        {
          "rule": "Unbound assets",
          "enforcement": "must"
        },
        {
          "rule": "Generated readable Chinese or exact mathematical quantity",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Every visual requirement resolves to an asset or deterministic local layer",
          "enforcement": "must"
        },
        {
          "criterion": "Prompt states subject position and crop intent",
          "enforcement": "should"
        },
        {
          "criterion": "Output dimensions match placement",
          "enforcement": "must"
        }
      ],
      "repairTarget": "failed_asset_ids",
      "recommendedNext": [
        "ppt_asset_generation"
      ]
    },
    {
      "id": "ppt_asset_generation",
      "version": "v2",
      "purpose": "Generate or reconstruct exactly one planned PPT asset while preserving deterministic text and mathematics as local layers.",
      "requiredInputs": [
        "approved_asset_request",
        "visual_system",
        "provider_profile"
      ],
      "requiredOutputs": [
        "asset_id",
        "asset_file",
        "actual_dimensions",
        "provider_metadata",
        "source_refs",
        "local_overlay_manifest"
      ],
      "forbidden": [
        {
          "rule": "Generating unplanned assets",
          "enforcement": "must"
        },
        {
          "rule": "Baking readable Chinese, formulas, or exact quantities into raster images",
          "enforcement": "must"
        },
        {
          "rule": "Accepting an API response without a real decodable file",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Asset file exists and decodes",
          "enforcement": "must"
        },
        {
          "criterion": "Dimensions and safe zones match the request",
          "enforcement": "must"
        },
        {
          "criterion": "asset_id and source refs are traceable",
          "enforcement": "must"
        },
        {
          "criterion": "Local overlay requirements remain editable",
          "enforcement": "should"
        }
      ],
      "repairTarget": "asset_id",
      "recommendedNext": [
        "ppt_asset_review"
      ]
    },
    {
      "id": "ppt_asset_review",
      "version": "v2",
      "purpose": "Review every real PPT asset against its bound request before PPTX generation can begin.",
      "requiredInputs": [
        "generated_ppt_assets",
        "ppt_asset_plan",
        "ppt_page_specs"
      ],
      "requiredOutputs": [
        "required_asset_ids",
        "approved_asset_ids",
        "asset_scores",
        "technical_checks",
        "findings",
        "failed_asset_ids",
        "repair_routes"
      ],
      "forbidden": [
        {
          "rule": "Approving from prompts alone",
          "enforcement": "must"
        },
        {
          "rule": "Passing unresolved asset IDs",
          "enforcement": "must"
        },
        {
          "rule": "Ignoring generated text, logos, watermarks, crop, or safe-zone failures",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "Every required asset ID has exactly one reviewed file",
          "enforcement": "must"
        },
        {
          "criterion": "approved_asset_ids equals required_asset_ids before PPTX generation",
          "enforcement": "must"
        },
        {
          "criterion": "Every file decodes and matches its placement dimensions",
          "enforcement": "must"
        },
        {
          "criterion": "Generated text, exact-count, crop, copyright, and safe-zone checks pass",
          "enforcement": "must"
        }
      ],
      "transitionRules": [
        "Proceed only when set(approved_asset_ids) == set(required_asset_ids); otherwise rerun ppt_asset_generation for failed_asset_ids only"
      ],
      "repairTarget": "failed_asset_ids",
      "recommendedNext": [
        "pptx_generation"
      ]
    },
    {
      "id": "ppt_render_review",
      "version": "v2",
      "purpose": "Review the real rendered PPTX, not its prompt or design draft.",
      "requiredInputs": [
        "pptx_artifact",
        "ppt_page_specs",
        "rendered_slides",
        "evidence_package"
      ],
      "requiredOutputs": [
        "artifact_truth",
        "deck_score",
        "page_scores",
        "findings",
        "failed_page_ids",
        "repair_routes"
      ],
      "forbidden": [
        {
          "rule": "Passing from slide count alone",
          "enforcement": "must"
        },
        {
          "rule": "Reviewing only a contact sheet",
          "enforcement": "must"
        },
        {
          "rule": "Vague aesthetic feedback",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "PPTX structure and slide count pass",
          "enforcement": "must"
        },
        {
          "criterion": "Every page is inspected full-size",
          "enforcement": "should"
        },
        {
          "criterion": "No critical math/evidence error",
          "enforcement": "must"
        },
        {
          "criterion": "No overflow, clipping, unreadable contrast, or missing primary visual",
          "enforcement": "must"
        },
        {
          "criterion": "Alt text, reading order, non-color encoding, and required media captions/transcripts pass",
          "enforcement": "must"
        },
        {
          "criterion": "Weighted score at least 80 and every hard gate at least 3/4",
          "enforcement": "should"
        }
      ],
      "repairTarget": "failed_page_ids",
      "recommendedNext": [
        "cross_delivery_review"
      ]
    },
    {
      "id": "pptx_generation",
      "version": "v2",
      "purpose": "Generate a real editable PPTX from approved PageSpecs and bound assets without changing the learning sequence.",
      "requiredInputs": [
        "approved_ppt_page_specs",
        "approved_ppt_assets",
        "visual_system"
      ],
      "requiredOutputs": [
        "pptx_file",
        "slide_count",
        "page_spec_mapping",
        "asset_mapping",
        "accessibility_mapping",
        "generation_metadata"
      ],
      "forbidden": [
        {
          "rule": "Adding explanation slides",
          "enforcement": "must"
        },
        {
          "rule": "Merging PageSpecs",
          "enforcement": "must"
        },
        {
          "rule": "Replacing editable math layers with raster text",
          "enforcement": "must"
        },
        {
          "rule": "Claiming success before PPTX validation",
          "enforcement": "must"
        }
      ],
      "qualityGates": [
        {
          "criterion": "PPTX container and presentation.xml exist",
          "enforcement": "should"
        },
        {
          "criterion": "slide_count equals approved PageSpec count",
          "enforcement": "must"
        },
        {
          "criterion": "Every page_id maps to exactly one slide",
          "enforcement": "must"
        },
        {
          "criterion": "Every required asset resolves",
          "enforcement": "must"
        },
        {
          "criterion": "Alt text and reading order are written to the editable PPTX",
          "enforcement": "must"
        },
        {
          "criterion": "Embedded media has captions or transcript when required",
          "enforcement": "should"
        }
      ],
      "repairTarget": "failed_page_or_asset_ids",
      "recommendedNext": [
        "ppt_render_review"
      ]
    },
    {
      "id": "video_concept_set",
      "version": "v2",
      "purpose": "Produce an intro-video concept set appropriate to the current exploration or teacher-provided selection mode.",
      "requiredInputs": [
        "delivery_strategy",
        "course_anchor",
        "lesson_plan",
        "concept_set_mode"
      ],
      "requiredOutputs": [
        "concept_set_mode",
        "design_id",
